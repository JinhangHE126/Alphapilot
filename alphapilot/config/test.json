{
    "dns": {
        "final": "bootstrap-dns",
        "servers": [
            {
                "server": "223.5.5.5",
                "server_port": 53,
                "tag": "bootstrap-dns",
                "type": "udp"
            },
            {
                "server": "1.1.1.1",
                "server_port": 53,
                "tag": "cloudflare-dns",
                "type": "udp"
            }
        ],
        "strategy": "prefer_ipv4"
    },
    "experimental": {
        "clash_api": {
            "external_controller": "127.0.0.1:62631"
        }
    },
    "inbounds": [
        {
            "listen": "127.0.0.1",
            "listen_port": 7896,
            "tag": "market-agent",
            "type": "mixed"
        },
        {
            "listen": "127.0.0.1",
            "listen_port": 7898,
            "tag": "news-agent",
            "type": "mixed"
        },
        {
            "listen": "127.0.0.1",
            "listen_port": 7899,
            "tag": "llm-agent",
            "type": "mixed"
        }
    ],
    "log": {
        "level": "info"
    },
    "outbounds": [
        {
            "default": "sakuracat-http",
            "outbounds": [
                "sakuracat-http",
                "direct"
            ],
            "tag": "agent-proxy",
            "type": "selector"
        },
        {
            "server": "127.0.0.1",
            "server_port": 7897,
            "tag": "sakuracat-http",
            "type": "http"
        },
        {
            "tag": "direct",
            "type": "direct"
        }
    ],
    "route": {
        "default_domain_resolver": {
            "server": "bootstrap-dns",
            "strategy": "prefer_ipv4"
        },
        "final": "direct",
        "rules": [
            {
                "action": "sniff",
                "inbound": "market-agent"
            },
            {
                "action": "sniff",
                "inbound": "news-agent"
            },
            {
                "action": "sniff",
                "inbound": "llm-agent"
            },
            {
                "inbound": [
                    "market-agent"
                ],
                "outbound": "agent-proxy"
            },
            {
                "inbound": [
                    "news-agent"
                ],
                "outbound": "agent-proxy"
            },
            {
                "inbound": [
                    "llm-agent"
                ],
                "outbound": "agent-proxy"
            }
        ]
    }
}